  function updateTotalStyle(viewId) {
    const view = document.getElementById(viewId);
    if (!view) return;

    const totalEl = view.querySelector(`[data-testid="${TOTAL_TESTID}"]`);
    if (!totalEl) return;

    const block = totalEl.closest(".kn-input") || totalEl.parentElement;
    if (!block) return;

    const total = num(totalEl.textContent);
