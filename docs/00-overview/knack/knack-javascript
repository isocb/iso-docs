        [ATOM_DIMS.city]: dims.city,
        [ATOM_DIMS.reporter]: dims.reporter,
      });
    }

    return atoms;
  }

async function getAllAtomsForSubmission(submissionId) {
  let page = 1;
  let all = [];

  while (true) {
    const res = await listAtomsForSubmission(submissionId, page, 1000);
    const records = res?.records || [];
    all = all.concat(records);

    // stop when fewer than requested are returned
    if (!records.length || records.length < 1000) break;
    page += 1;
  }

  return all;
}

  async function atomiseSubmission(submissionId, prefetchedRecord) {
    dlog("Atomise start", submissionId, prefetchedRecord ? "(has prefetched record from XHR)" : "(will fetch via details view)");

    let submission;
    if (prefetchedRecord && Object.keys(prefetchedRecord).length > 0) {
      // Try using the record data captured from the XHR save response
      const flat = normaliseRecordToFieldMap(prefetchedRecord);
      const fieldCount = Object.keys(flat).filter(k => /^field_\d+$/.test(k)).length;
      dlog("Prefetched record normalised, field count:", fieldCount);
      if (fieldCount > 0) {
        submission = flat;
      } else {
        dlog("⚠️ Prefetched record had 0 fields after normalisation, falling back to details view");
        submission = await getSubmissionRecord(submissionId);
      }
    } else {
      submission = await getSubmissionRecord(submissionId);
    }
    dlog("Submission record ready");

    const atoms = buildAtomPayloads(submissionId, submission);
    dlog("Atoms built", atoms.length);

    const existing = await getAllAtomsForSubmission(submissionId);
    dlog("Existing atoms found", existing.length);

    await runWithConcurrency(existing.map(r => r.id), deleteAtom, DELETE_CONCURRENCY);
    dlog("Delete complete");

    let created = 0;
    await runWithConcurrency(atoms, async (payload) => { await createAtom(payload); created += 1; }, CREATE_CONCURRENCY);
    dlog("Create complete", created);

    dlog("✅ Atomisation complete", { created, deleted: existing.length });
    return { created, deleted: existing.length };
  }

