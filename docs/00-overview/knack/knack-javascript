(function () {
  const EDIT_VIEW_IDS = ["view_69"]; // add your edit views here
  const CITY_TOTAL_NAME = "field_380"; // City Work Area Total input field name

  function toNumber(v) {
    const n = parseFloat(String(v ?? "").trim().replace(",", "."));
    return Number.isFinite(n) ? n : 0;
  }

  function ensureCityTotalDisplay(viewId) {
    const view = document.getElementById(viewId);
    if (!view) return;

    const form = view.querySelector("form");
    if (!form) return;

    const wrap = form.querySelector(`.kn-input.${CITY_TOTAL_NAME}`);
    const input = form.querySelector(`input[name="${CITY_TOTAL_NAME}"]`);
    if (!wrap || !input) return;

    // 1) Hide the input so it doesn't look editable (keep it in DOM for saving)
    if (input.style.display !== "none") input.style.display = "none";

    // 2) Create the "equation style" display ONCE
    let display = wrap.querySelector(`[data-tci-citytotal-display="${viewId}"]`);
    if (!display) {
      display = document.createElement("div");
      display.setAttribute("data-tci-citytotal-display", viewId);
      display.className = "flex items-center gap-2";
      display.style.marginTop = "0.25rem";

      display.innerHTML = `
        <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 20 20"
             aria-hidden="true" height="20" width="20" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd"
            d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm1 2a1 1 0 000 2h6a1 1 0 100-2H7zm6 7a1 1 0 011 1v3a1 1 0 11-2 0v-3a1 1 0 011-1zm-3 3a1 1 0 100 2h.01a1 1 0 100-2H10zm-4 1a1 1 0 011-1h.01a1 1 0 110 2H7a1 1 0 01-1-1zm1-4a1 1 0 100 2h.01a1 1 0 100-2H7zm2 1a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1zm4-4a1 1 0 100 2h.01a1 1 0 100-2H13zM9 9a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1zM7 8a1 1 0 000 2h.01a1 1 0 000-2H7z"
            clip-rule="evenodd"></path>
        </svg>
        <span data-tci-citytotal-value="${viewId}">0</span>
      `;

      // Insert right after the label (matches Knack equation layout)
      const label = wrap.querySelector("label");
      if (label && label.parentNode) {
        label.parentNode.insertBefore(display, label.nextSibling);
      } else {
        wrap.appendChild(display);
      }
    }

    // 3) Update value text (lightweight)
    const span = wrap.querySelector(`[data-tci-citytotal-value="${viewId}"]`);
    if (span) span.textContent = String(toNumber(input.value));
  }

  // Throttle with rAF so we don't spam DOM updates while typing
  let scheduled = false;
  function schedule() {
    if (scheduled) return;
    scheduled = true;
    requestAnimationFrame(() => {
      scheduled = false;
      EDIT_VIEW_IDS.forEach(ensureCityTotalDisplay);
    });
  }

  // Update whenever the user types anywhere in the form
  document.addEventListener("input", (e) => {
    if (EDIT_VIEW_IDS.some(id => e.target.closest(`#${id}`))) schedule();
  }, true);

  document.addEventListener("change", (e) => {
    if (EDIT_VIEW_IDS.some(id => e.target.closest(`#${id}`))) schedule();
  }, true);

  // Backstop: run occasionally in case Knack re-renders / conditional visibility changes
  if (window.__tciCityTotalDisplayInterval) clearInterval(window.__tciCityTotalDisplayInterval);
  window.__tciCityTotalDisplayInterval = setInterval(schedule, 800);

  // Initial
  schedule();
})();



