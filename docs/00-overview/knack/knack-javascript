  function toNumber(val) {
  // Next-Gen sometimes returns objects like { value: "5" } or { raw: "5" }
  if (val && typeof val === "object") {
    val = val.value ?? val.raw ?? val.number ?? val.amount ?? val.text ?? "";
  }
  const n = typeof val === "number" ? val : parseFloat(String(val).replace(",", "."));
  return Number.isFinite(n) ? n : 0;
}

function isPositiveNumber(val) {
  return toNumber(val) > EPSILON;
}

  function normaliseConnValue(v) {
    if (!v) return "";
    if (typeof v === "string") return v;
    if (Array.isArray(v)) {
      const ids = v.map(x => (typeof x === "string" ? x : x?.id)).filter(Boolean);
      if (!ids.length) return "";
      return ids.length === 1 ? ids[0] : ids;
    }
    if (typeof v === "object" && v.id) return v.id;
    return "";
  }

