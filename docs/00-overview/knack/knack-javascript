    if (scheduled) return;
    scheduled = true;
    requestAnimationFrame(() => {
      scheduled = false;
      EDIT_VIEW_IDS.forEach(updateTotalStyle);
    });
  }

  document.addEventListener("input", (e) => {
    if (EDIT_VIEW_IDS.some(id => e.target.closest(`#${id}`))) schedule();
  }, true);

  if (window.__tciTotalStyleInterval) clearInterval(window.__tciTotalStyleInterval);
  window.__tciTotalStyleInterval = setInterval(schedule, 400);

  schedule();
})();

// Solve the protential problem of the submit button being out of sight because of the number of cities in Utta Pradesh!!
(function () {
  // ====== CONFIG ======
  const EDIT_VIEW_IDS = ["view_69"]; // add more edit-form view ids here
  const TOTAL_LABEL_TEXT = "Total Submission Value"; // <-- what the user sees
  const REQUIRED = 100;
  const EPSILON = 0.001;

  // tints
  const OK_BG = "rgba(146, 224, 128, 0.22)";   // light #92E080
  const BAD_BG = "rgba(220, 38, 24, 0.16)";
  const OK_BORDER = "rgba(146, 224, 128, 0.6)";
  const BAD_BORDER = "rgba(220, 38, 24, 0.45)";

  // ====== HELPERS ======
  const norm = (s) => String(s || "").replace(/\s+/g, " ").trim().toLowerCase();

  function toNum(text) {
    const n = parseFloat(String(text || "").trim().replace(",", "."));
    return Number.isFinite(n) ? n : NaN;
  }
  function isOk(total) {
    return Number.isFinite(total) && Math.abs(total - REQUIRED) < EPSILON;
  }

  function findTotalBlockByLabel(view) {
    const want = norm(TOTAL_LABEL_TEXT);

    // Find a .kn-input whose label text matches "Total Submission Value"
    const blocks = view.querySelectorAll(".kn-input");
    for (const b of blocks) {
      const label = b.querySelector("label .kn-rich-text-renderer, label");
      const labelText = norm(label ? label.textContent : "");
      if (labelText === want) return b;
    }
    return null;
  }

  function findEquationSpanWithin(block) {
    if (!block) return null;

    // Typical equation span: <span data-testid="form-view-equation-input-field_XXX">
    const span = block.querySelector('span[data-testid^="form-view-equation-input-field_"]');
    return span || null;
  }

  function processView(viewId) {
    const view = document.getElementById(viewId);
    if (!view) return;

    const form = view.querySelector("form");
    if (!form) return;

    // 1) Locate the total block by label text (no field id needed)
    const totalBlock = findTotalBlockByLabel(view);
    if (!totalBlock) return;

    // 2) Find the equation span inside it
    const totalSpan = findEquationSpanWithin(totalBlock);
    if (!totalSpan) return;

    // Read + validate
    const total = toNum(totalSpan.textContent);
    const ok = isOk(total);

    // Tint the total block itself
    totalBlock.style.backgroundColor = ok ? OK_BG : BAD_BG;
    totalBlock.style.border = `1px solid ${ok ? OK_BORDER : BAD_BORDER}`;
    totalBlock.style.borderRadius = "8px";
    totalBlock.style.paddingLeft = "10px";
    totalBlock.style.paddingRight = "10px";

    // Find submit row (contains Knack submit button)
    const btn = form.querySelector('button[type="submit"]');
    if (!btn) return;

    const submitRow = btn.closest(".flex.gap-4") || btn.parentElement;
    if (!submitRow) return;

    // Panel that will hold note + button, positioned under Total Submission Value block
    let panel = form.querySelector(`[data-tci-submit-panel="${viewId}"]`);
    if (!panel) {
      panel = document.createElement("div");
      panel.setAttribute("data-tci-submit-panel", viewId);
      panel.style.borderRadius = "12px";
      panel.style.padding = "12px";
      panel.style.marginTop = "10px";
      panel.style.marginBottom = "12px";
      panel.style.transition = "background-color 120ms ease, border-color 120ms ease";

      // Insert panel AFTER total block
      totalBlock.insertAdjacentElement("afterend", panel);
    }

    // Move the submit row into the panel (so it stays under the total field)
    if (!panel.contains(submitRow)) panel.appendChild(submitRow);

    // Panel tint
    panel.style.backgroundColor = ok ? OK_BG : BAD_BG;
    panel.style.border = `1px solid ${ok ? OK_BORDER : BAD_BORDER}`;

    // Button state (optional: keep your existing guard behaviour)
    btn.disabled = !ok;
    btn.style.opacity = ok ? "1" : "0.5";
    btn.style.cursor = ok ? "pointer" : "not-allowed";

    // Note text (create once if missing)
    let note = submitRow.querySelector(`[data-tci-submit-note="${viewId}"]`);
    if (!note) {
      note = document.createElement("div");
      note.setAttribute("data-tci-submit-note", viewId);
      note.style.maxWidth = "44ch";
      note.style.fontSize = "0.9rem";
      note.style.opacity = "0.85";
      note.style.lineHeight = "1.3";
      note.style.marginRight = "10px";
      submitRow.insertBefore(note, btn);
    }

    note.textContent = ok
      ? "Total equals 100%. You can submit this form."
      : "You can submit once the Total Submission Value equals 100%.";

    // Make submit row tidy
    submitRow.style.justifyContent = "flex-end";
    submitRow.style.alignItems = "center";
  }

  // ====== SCHEDULER (safe) ======
  let scheduled = false;
  function schedule() {
    if (scheduled) return;
    scheduled = true;
    requestAnimationFrame(() => {
      scheduled = false;
      EDIT_VIEW_IDS.forEach(processView);
    });
  }

  // React to user input and Knack re-rendering
  document.addEventListener(
    "input",
    (e) => {
      if (EDIT_VIEW_IDS.some((id) => e.target.closest(`#${id}`))) schedule();
    },
    true
  );

  if (window.__tciSubmitPanelInterval_autoTotal) {
    clearInterval(window.__tciSubmitPanelInterval_autoTotal);
  }
  window.__tciSubmitPanelInterval_autoTotal = setInterval(schedule, 600);

  schedule();
})();

