//Colour the total value to give a red and green visual clue about the status of the data.

(function () {
  const EDIT_VIEW_IDS = ["view_69"]; // add other edit views here
  const TOTAL_TESTID = "form-view-equation-input-field_382";
  const REQUIRED = 100;
  const EPSILON = 0.001;

  const OK_BG = "rgba(146, 224, 128, 0.25)";     // #92E080 light
  const BAD_BG = "rgba(220, 38, 24, 0.18)";      // soft red
  const OK_BORDER = "rgba(146, 224, 128, 0.65)";
  const BAD_BORDER = "rgba(220, 38, 24, 0.45)";

  function num(text) {
    const n = parseFloat(String(text || "").trim().replace(",", "."));
    return Number.isFinite(n) ? n : NaN;
