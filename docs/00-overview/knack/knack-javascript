      reporter: normaliseConnValue(submissionRecord[ATOM_DIMS.reporter]),
    };

    dlog("Dims parsed", dims);

    const atoms = [];
    const seen = new Set();

    for (const submissionFieldKey of Object.keys(FIELD_MAP)) {
      const meta = FIELD_MAP[submissionFieldKey];
      const rawVal = submissionRecord[submissionFieldKey];
      if (!isPositiveNumber(rawVal)) continue;

      const value = toNumber(rawVal);
      const dedupe = `${submissionId}|${meta.type}|${meta.item}`;
      if (seen.has(dedupe)) continue;
      seen.add(dedupe);

      atoms.push({
        [ATOM_FIELDS.submissionConn]: submissionId,
        [ATOM_FIELDS.typeText]: meta.type,
