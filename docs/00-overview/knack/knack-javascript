  function extractIdFromUrl(url) {
    const m = String(url || "").match(/\/views\/view_\d+\/records\/([^/]+)\/?$/);
    return m ? m[1] : null;
  }
  function isAddUrl(url) { return String(url || "").includes(`/views/${CREATE_VIEW}/records`); }
  function isEditUrl(url) { return String(url || "").includes(`/views/${EDIT_VIEW}/records`); }

  if (!window.__ATOMISER_XHR_WRAPPED__) {
    window.__ATOMISER_XHR_WRAPPED__ = true;

    const origOpen = XMLHttpRequest.prototype.open;
    const origSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function (method, url) {
      this.__atom_method = String(method || "").toUpperCase();
      this.__atom_url = url;
      return origOpen.apply(this, arguments);
    };

    XMLHttpRequest.prototype.send = function () {
      this.addEventListener("loadend", async () => {
        try {
          const method = this.__atom_method;
          const url = this.__atom_url;

          if (!(this.status >= 200 && this.status < 300)) return;
          if (!["POST", "PUT", "PATCH"].includes(method)) return;

          // Phase 1: create submission -> capture id
          if (method === "POST" && isAddUrl(url)) {
            let id = null;
            try {
              const data = JSON.parse(this.responseText || "{}");
              id = data?.record?.id || data?.id || null;
            } catch (_) { }

            if (id) {
              dlog("✅ Phase 1 create saved, captured id", id);
              safeSetPending(id);
            }
            return;
          }

          // Phase 2: edit submission -> atomise
          // The XHR PUT/PATCH response contains the full saved record — capture it
          // as a primary data source, with the details view as fallback.
          if ((method === "PUT" || method === "PATCH") && isEditUrl(url)) {
            const idFromUrl = extractIdFromUrl(url);
            const pending = safeGetPending();
            const submissionId = pending || idFromUrl;

            // Extract saved record from XHR response body
            let savedRecord = null;
            try {
              const responseData = JSON.parse(this.responseText || "{}");
              savedRecord = responseData?.record || responseData || null;
              const fieldKeys = Object.keys(savedRecord || {}).filter(k => k.startsWith("field_"));
              dlog("✅ Phase 2 edit saved, will atomise", {
                pending, idFromUrl, submissionId,
                xhrFieldKeys: fieldKeys.length,
                sampleKeys: fieldKeys.slice(0, 8)
              });
            } catch (_) {
              dlog("⚠️ Could not parse XHR response, will use details view instead");
            }

            if (!submissionId) return;
            safeClearPending();

            try {
              await atomiseSubmission(submissionId, savedRecord);
            } catch (e) {
              derr("💥 ATOMISATION FAILED", e);
            }
          }
        } catch (e) {
          derr("💥 Save detector error", e);
        }
      });

      return origSend.apply(this, arguments);
    };

    dlog("✅ XHR save detector installed", {
      submission: { CREATE_VIEW, EDIT_VIEW },
      atoms: { ATOM_CREATE_VIEW, ATOM_GRID_VIEW }
    });
  }
