//This javascript does the mathematics, and applies the submit guardrail at 100.  The final section applies a visibility enhancement for fields that have values.


(function () {



  // ====== CONFIG (edit these only) ======
  const EDIT_VIEW_IDS = ["view_69"]; // add all your EDIT views here (not the ADD views)

  const ANCHOR_FIELD_CLASS = "field_447"; // Region field wrapper
  const CITY_TOTAL_FIELD_NAME = "field_380"; // stored number input (City Work Area Total)
  const TOTAL_SUBMISSION_TESTID = "form-view-equation-input-field_382"; // equation span

  const REQUIRED = 100;
  const EPSILON = 0.001;

  // Non-city numeric fields to exclude (add if needed)
  const EXCLUDE_FIELD_NAMES = new Set([
    CITY_TOTAL_FIELD_NAME,
    "field_371", "field_372", "field_373", "field_374" // your non-city work areas (update if different)
  ]);

  // Fields that mean "stop scanning - cities end here"
  const STOP_AT_FIELD_CLASSES = new Set([
    "field_380", // City Work Area Total
    "field_381", // Non City Work Area Total
    "field_382"  // Total Submission Value (equation)
  ]);
  // =====================================

  // Inject compact layout CSS once
  if (!document.getElementById("tci-city-css")) {
    const s = document.createElement("style");
    s.id = "tci-city-css";
    s.textContent = `
      .tci-city-row { display:flex; align-items:center; gap:12px; padding-top:6px !important; padding-bottom:6px !important; }
      .tci-city-row > label { flex:0 0 220px; margin:0 !important; }
      .tci-city-row input { flex:1 1 auto; }
      .tci-submit-note { font-size:0.9rem; opacity:0.75; margin-bottom:6px; line-height:1.3; max-width:40ch; }
    `;
    document.head.appendChild(s);
  }

  function isVisible(el) {
    return !!(el && (el.offsetWidth || el.offsetHeight || el.getClientRects().length));
  }

  function num(val) {
    const n = parseFloat(String(val || "").trim().replace(",", "."));
    return Number.isFinite(n) ? n : 0;
  }

  let scheduled = false;
  function schedule() {
    if (scheduled) return;
    scheduled = true;
    requestAnimationFrame(() => {
      scheduled = false;
      tick();
    });
  }

  function ensureNote(btn, viewId) {
    let note = btn.parentElement.querySelector(`[data-tci-submit-note="${viewId}"]`);
    if (!note) {
      note = document.createElement("div");
      note.className = "tci-submit-note";
      note.setAttribute("data-tci-submit-note", viewId);
      btn.parentElement.insertBefore(note, btn);
    }
    return note;
  }

  function getBlocks(form) {
    return Array.from(form.querySelectorAll(".kn-input"));
  }

  function isStopBlock(block) {
    for (const cls of STOP_AT_FIELD_CLASSES) {
      if (block.classList.contains(cls)) return true;
    }
    return false;
  }

  function collectCityInputsAfterAnchor(form) {
    const blocks = getBlocks(form);
    const anchorIndex = blocks.findIndex(b => b.classList.contains(ANCHOR_FIELD_CLASS));
    if (anchorIndex < 0) return []; // anchor not found

    const cityInputs = [];

    for (let i = anchorIndex + 1; i < blocks.length; i++) {
      const block = blocks[i];

      // stop when we hit totals section or submit area
      if (isStopBlock(block)) break;
      if (block.querySelector('button[type="submit"]')) break;

      const inp = block.querySelector('input[placeholder="Enter a number"][name^="field_"]');
      if (!inp) continue;

      if (EXCLUDE_FIELD_NAMES.has(inp.name)) continue;

      // treat as city input
      block.classList.add("tci-city-row");
      if (isVisible(inp)) cityInputs.push(inp);
    }

    return cityInputs;
  }

  function updateCityTotal(viewId) {
    const view = document.getElementById(viewId);
    if (!view) return;

    const form = view.querySelector("form");
    if (!form) return;

    const cityInputs = collectCityInputsAfterAnchor(form);

    const total = cityInputs.reduce((sum, inp) => sum + num(inp.value), 0);
    const rounded = Math.round(total * 1000) / 1000;

    const totalInput = form.querySelector(`input[name="${CITY_TOTAL_FIELD_NAME}"]`);
    if (!totalInput) return;

    const current = num(totalInput.value);
    if (Math.abs(current - rounded) > EPSILON) {
      totalInput.value = String(rounded);
      totalInput.dispatchEvent(new Event("input", { bubbles: true }));
      totalInput.dispatchEvent(new Event("change", { bubbles: true }));
    }
  }

  function guardSubmit(viewId) {
    const view = document.getElementById(viewId);
    if (!view) return;

    const btn = view.querySelector('button[type="submit"]');
    if (!btn) return;

    const totalEl = view.querySelector(`[data-testid="${TOTAL_SUBMISSION_TESTID}"]`);
    if (!totalEl) return;

    const total = num(totalEl.textContent);
    const ok = Math.abs(total - REQUIRED) < EPSILON;

    const note = ensureNote(btn, viewId);
    btn.disabled = !ok;
    btn.style.opacity = ok ? "1" : "0.5";
    btn.style.cursor = ok ? "pointer" : "not-allowed";
    note.textContent = ok
      ? "Total equals 100%. You can submit this form."
      : "You can submit once the Total Submission Value equals 100%.";
  }

  function tick() {
    for (const id of EDIT_VIEW_IDS) {
      updateCityTotal(id);
      guardSubmit(id);
    }
  }

  // Recalc on typing
  document.addEventListener("input", (e) => {
    if (EDIT_VIEW_IDS.some(id => e.target.closest(`#${id}`))) schedule();
  }, true);

  // Recalc on re-render / show-hide
  const container =
    document.querySelector('[data-testid="page-container"]') ||
    document.getElementById("root") ||
    document.body;

  const obs = new MutationObserver(schedule);
  obs.observe(container, { childList: true, subtree: true });

  schedule();
  setTimeout(schedule, 500);
  setTimeout(schedule, 1500);
})();

