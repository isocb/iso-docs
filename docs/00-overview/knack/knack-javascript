  async function viewFetch(sceneId, viewId, { method = "GET", recordId = null, body = null } = {}) {
  if (!sceneId) throw new Error("No sceneId provided to viewFetch");
  if (!viewId) throw new Error("No viewId provided to viewFetch");

  const pathsToTry = [
    `/api/v1/pages/${sceneId}/views/${viewId}/records`, // Builder Next (common)
    `/v1/pages/${sceneId}/views/${viewId}/records`,     // Live app / some builds
  ];

  const makeUrl = (base) => (recordId ? `${base}/${recordId}` : base);

  const opts = {
    method,
    credentials: "same-origin",
    headers: { "Content-Type": "application/json" },
  };
  if (body) opts.body = JSON.stringify(body);

  let lastErr = null;

  for (const base of pathsToTry) {
    const url = makeUrl(base);
    if (DEBUG) console.log("[Atomiser]", new Date().toISOString(), "VIEW FETCH", method, url);

    try {
      const res = await fetch(url, opts);
      const text = await res.text();

      // If we accidentally hit an HTML page (login/redirect), fail clearly
      const looksLikeHtml = text && text.trim().startsWith("<");
      let data = null;
      if (!looksLikeHtml) {
        try { data = text ? JSON.parse(text) : null; } catch (_) {}
      }

      if (!res.ok) {
        const msg = looksLikeHtml ? text.slice(0, 200) : (data ? JSON.stringify(data) : text);
        throw new Error(`View API ${res.status} via ${base}: ${msg}`);
      }

      // Success
      return data ?? {};
    } catch (e) {
      lastErr = e;
      // try next base
    }
  }

  throw lastErr || new Error("ViewFetch failed for all base paths");
}

function normaliseRecordToFieldMap(res) {
  // Strategy 0: If res has a records[] array (View API sometimes wraps single-record GETs)
  if (Array.isArray(res?.records) && res.records.length > 0) {
    dlog("normalise: using res.records[0]");
    return normaliseRecordToFieldMap(res.records[0]);
  }

  const r = res?.record || res || {};

  // Strategy 1: Direct field_### keys (no suffix like _raw)
  const directFieldKeys = Object.keys(r).filter(k => /^field_\d+$/.test(k));
  if (directFieldKeys.length > 0) {
    dlog("normalise: direct field_ keys found:", directFieldKeys.length);
    return r;
  }

  // Strategy 2: Knack Next-Gen returns field_###_raw alongside HTML display values
  //   e.g. field_371: "<span>5</span>", field_371_raw: 5
  //   The _raw values are what we need for numeric extraction
  const rawKeys = Object.keys(r).filter(k => /^field_\d+_raw$/.test(k));
  if (rawKeys.length > 0) {
    dlog("normalise: _raw keys found, extracting:", rawKeys.length);
    const out = { id: r.id };
    for (const rawKey of rawKeys) {
      const cleanKey = rawKey.replace(/_raw$/, ""); // field_371_raw -> field_371
      out[cleanKey] = r[rawKey];
    }
    return out;
  }

  // Strategy 3: fields as an array of objects
  if (Array.isArray(r.fields)) {
    dlog("normalise: fields array found, length:", r.fields.length);
    const out = { id: r.id };
    for (const f of r.fields) {
      const key = f?.key || f?.field || f?.field_key || f?.name;
      if (key && /^field_\d+$/.test(key)) out[key] = f.value ?? f.val ?? f.raw ?? f.display ?? "";
    }
    return out;
  }

  // Strategy 4: field_values nested object
  if (r.field_values && typeof r.field_values === "object") {
    dlog("normalise: field_values object found");
    return { id: r.id, ...r.field_values };
  }

  // Strategy 5: Any keys matching field_### with suffixes (_raw, _formatted, etc.)
  const anyFieldKeys = Object.keys(r).filter(k => /^field_\d+/.test(k));
  if (anyFieldKeys.length > 0) {
    dlog("normalise: mixed field keys found, building map from", anyFieldKeys.length, "keys");
    const out = { id: r.id };
    for (const k of anyFieldKeys) {
      const baseKey = k.replace(/_(raw|formatted|display|html)$/, "");
      if (/^field_\d+$/.test(baseKey) && !(baseKey in out)) {
        out[baseKey] = r[baseKey + "_raw"] ?? r[baseKey] ?? "";
      }
    }
    return out;
  }

  // Fallback: return as-is
  dlog("normalise: FALLBACK — no field keys found at all. Keys:", Object.keys(r).slice(0, 20));
  return r;
}

